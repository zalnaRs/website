<script>
  import sal from 'sal.js';
  import 'sal.js/dist/sal.css';
  sal({
    // once: false,
    duration: 1000,
  } as unknown as any);
</script>

<style>
@tailwind base;
  @layer base {
    * {
      @apply scroll-smooth font-sans transition-all ease-in-out-expo;
    }

    html,
    body {
      @apply bg-amber-50 text-gray-800 scroll-smooth;
    }

    /* .material-symbols-outlined { */
    /*   font-variation-settings: */
    /*     'FILL' 0, */
    /*     'wght' 700, */
    /*     'GRAD' 200, */
    /*     'opsz' 24; */
    /* } */

    @media (prefers-color-scheme: dark) {
      html,
      body {
        @apply bg-gray-800 text-gray-100;
      }
    }
  }
</style>

<noscript>
  <style type="text/css">
    [data-sal|='fade'] {
      opacity: 1;
    }

    [data-sal|='slide'],
    [data-sal|='zoom'] {
      opacity: 1;
      transform: none;
    }

    [data-sal|='flip'] {
      transform: none;
    }
  </style>
</noscript>
