---
import DownloadButton from './DownloadButton.astro';

type Download = {
  title: string;
  href: string;
};

const { download, repository, privacypolicy, termsandconditions } = Astro.props as {
  download: Download[] | string;
  repository: string;
  privacypolicy?: string;
  termsandconditions?: string;
};
---

<section class="m-auto flex gap-2 items-center w-full whitespace-nowrap my-4">
  {
    download && typeof download == 'string' ? (
      <a
        target="_blank"
        href={download}
        class="group flex items-center justify-center no-underline rounded p-2 px-4 h-20 w-48 transition-all"
      >
        {/*
        <span class="flex items-center justify-center gap-2 text-2xl font-black">
          <span class="material-symbols-outlined text-2xl group-hover:font-black transition-all bg-green-400 rounded-full h-8 w-8 text-center flex justify-center items-center">
            download
          </span>
          Download
        </span>*/}
        <DownloadButton />
      </a>
    ) : (
      typeof download === 'object' && (
        <div class="relative group flex flex-col transition-all w-48">
          <DownloadButton />
          <ul class="absolute -top-1 z-20 rounded w-full transition-all bg-lime-500 opacity-0 group-focus-within:opacity-100 flex-col duration-300 pointer-events-none group-focus-within:pointer-events-auto group-focus-within:top-24">
      {download.map((el, i) => (
              <li class="w-full text-center flex">
                <a
                  href={el.href}
                  target="_blank"
          class={`w-full flex rounded no-underline justify-center text-center py-4 hover:bg-lime-600 transition-all hover:underline ${i === download.length-1 ? "rounded-t-none rounded-b" : i === 0 ? "rounded-t rounded-b-none" : "rounded-t-none rounded-b-none"}`}

                >
                  {el.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )
    )
  }

  {
    repository && (
      <a
        target="_blank"
        href={repository}
        class="group flex items-center no-underline justify-center hover:bg-yellow-500 rounded p-2 px-4 h-20 w-48 transition-all"
      >
        <span class="flex items-center justify-center gap-2 text-2xl font-black">
          <span class="text-2xl group-hover:font-black transition-all bg-yellow-500 rounded-full h-8 w-8 text-center flex justify-center items-center">
          <img src="/img/icons/code.svg" alt="" />
      </span>
          Repository
        </span>
      </a>
    )
  }

  {
    privacypolicy && (
      <a
        target="_blank"
        href={privacypolicy}
        class="group flex items-center no-underline justify-center hover:bg-red-600 rounded p-2 px-4 h-20 w-58 transition-all"
      >
        <span class="flex items-center justify-center gap-2 text-2xl font-black">
          <span class="text-2xl group-hover:font-black transition-all bg-red-600 rounded-full h-8 w-8 text-center flex justify-center items-center">
          <img src="/img/icons/policy.svg" alt="" />
          </span>
          Privacy Policy
        </span>
      </a>
    )
  }

  {
    termsandconditions && (
      <a
        target="_blank"
        href={termsandconditions}
        class="group flex items-center no-underline justify-center hover:bg-purple-500 rounded p-2 px-4 h-20 w-84 transition-all"
      >
        <span class="flex items-center justify-center gap-2 text-2xl font-black">
          <span class="text-2xl group-hover:font-black transition-all bg-purple-500 rounded-full h-8 w-8 text-center flex justify-center items-center">
          <img src="/img/icons/gavel.svg" alt="" />
          </span>
          Terms And Conditions
        </span>
      </a>
    )
  }
</section>
